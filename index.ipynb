    "plt.figure(figsize=(10, 6))\n",
    "sns.countplot(data=dfFinal, x='Segmento', hue='Puntuacion_Gasto', palette='viridis')\n",
    "plt.title('Distribución de Puntuación de Gasto por Segmento', fontsize=14, fontweight='bold')\n",
